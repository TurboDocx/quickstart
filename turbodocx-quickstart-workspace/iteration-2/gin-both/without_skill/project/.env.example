# TurboDocx SDK Configuration
# Get your API key from https://app.turbodocx.com

# Required: Your TurboDocx API key
TURBODOCX_API_KEY=your_api_key_here

# Optional: Override the default API base URL
# TURBODOCX_BASE_URL=https://api.turbodocx.com

# TurboSign webhook secret (from your TurboDocx dashboard)
TURBOSIGN_WEBHOOK_SECRET=your_turbosign_webhook_secret_here

# TurboPartner webhook secret (from your TurboDocx dashboard)
TURBOPARTNER_WEBHOOK_SECRET=your_turbopartner_webhook_secret_here

# Server port
PORT=8080
