# TurboDocx API key (required) — get yours at https://app.turbodocx.com
TURBODOCX_API_KEY=your-api-key-here

# TurboDocx API base URL (optional, defaults to production)
TURBODOCX_BASE_URL=https://api.turbodocx.com

# Webhook URL for TurboSign status callbacks (optional)
TURBOSIGN_WEBHOOK_URL=https://your-domain.com/api/signatures/webhook
